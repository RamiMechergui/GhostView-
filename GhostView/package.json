{
  "name": "aegis",
  "version": "1.0.0",
  "description": "Privacy-focused browser with per-user workspaces",
  "main": "main.js",
  "build": {
    "appId": "com.aegis.browser",
    "productName": "AEGIS",
    "win": {
      "target": ["portable", "nsis"],
      "icon": "logo.ico",
      "signDlls": false,
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "AEGIS-${version}.exe",
      "requestExecutionLevel": "user"
    },
    "nsis": {
      "artifactName": "AEGIS-${version}-setup.exe",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "logo.ico",
      "uninstallDisplayName": "AEGIS Browser"
    },
    "directories": {
      "output": "dist"
    }
  },
  "scripts": {
    "start": "electron .",
    "pack": "electron-packager . AEGIS --platform=win32 --arch=x64 --icon=logo.ico --out=dist --overwrite",
    "portable": "electron-builder --win portable",
    "installer": "electron-builder --win nsis",
    "create-logo": "node create-logo.js",
    "clean": "Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "electron-packager": "^17.1.2",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.1"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.1"
  }
}
